    {
      "id": "filesystem-memory",
      "kind": "mcp",
      "name": "Filesystem Memory",
      "description": "Expose the OpenAgents memory directory through a filesystem MCP server.",
      "supported_tools": ["codex", "claude", "gemini"],
      "trust": "vetted",
      "source": "openagents",
      "install": {
        "managed_files": [
          {
            "relative_path": "mcp/filesystem-memory.yaml",
            "body": "name: filesystem-memory\ntrust: vetted\nsource: openagents\nmemory_root: ${memory_root}\n"
          }
        ],
        "mcp": {
          "codex": {
            "transport": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "${memory_root}"]
          },
          "claude": {
            "transport": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "${memory_root}"]
          },
          "gemini": {
            "transport": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "${memory_root}"]
          }
        }
      }
    },
